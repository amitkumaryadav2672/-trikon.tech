{
  "name": "voice-medical-assistant-server",
  "version": "1.0.0",
  "description": "Backend server for AI-Powered Voice Medical Appointment Booking Assistant",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "livekit-server-sdk": "^2.1.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2"
  }
}
